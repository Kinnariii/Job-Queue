{
  "name": "async-job-queue",
  "version": "1.0.0",
  "description": "Async job processing system with Redis, PostgreSQL, and Express",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "worker": "node src/workers/worker.js",
    "dev:server": "nodemon src/server.js",
    "dev:worker": "nodemon src/workers/worker.js",
    "test": "jest --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "uuid": "^9.0.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"]
  }
}
